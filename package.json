{
  "name": "community-articles",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write **/*.{js,ts,tsx,json,css,md,yml,html} .github/workflows/*.yml",
